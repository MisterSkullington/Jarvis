# J.A.R.V.I.S. Environment Variables
# Copy this file to .env and fill in your values.

# --- Profile ---
JARVIS_PROFILE=dev
JARVIS_LOG_LEVEL=INFO

# --- MQTT ---
JARVIS_MQTT_HOST=localhost

# --- LLM (Ollama) ---
JARVIS_LLM_ENABLED=false
# JARVIS_LLM_BASE_URL=http://localhost:11434

# --- Home Assistant ---
# HASS_TOKEN=your_long_lived_access_token_here

# --- Weather (OpenWeatherMap) ---
# OPENWEATHER_API_KEY=your_openweathermap_api_key

# --- News (NewsAPI) ---
# NEWS_API_KEY=your_newsapi_key

# --- Calendar (local ICS file path) ---
# JARVIS_ICS_PATH=/path/to/your/calendar.ics
