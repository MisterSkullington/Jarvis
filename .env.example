# Jarvis Assistant — Environment Variables
# Copy to .env and fill in your values.

# --- Config profile (loads config/<profile>.yaml on top of jarvis.example.yaml) ---
# JARVIS_PROFILE=dev

# --- MQTT override ---
# JARVIS_MQTT_HOST=localhost

# --- LLM ---
# JARVIS_LLM_ENABLED=true

# --- Logging ---
# JARVIS_LOG_LEVEL=INFO

# --- Home Assistant ---
# HASS_TOKEN=your_long_lived_access_token_here

# --- Email (if provider=smtp) ---
# EMAIL_PASSWORD=your_smtp_password_or_app_password

# --- Weather (OpenWeatherMap) ---
# OPENWEATHER_API_KEY=your_api_key_here

# --- News (NewsAPI) ---
# NEWS_API_KEY=your_api_key_here
